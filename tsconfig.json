{
  "compilerOptions": {
    "allowUnreachableCode": false,
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "noEmit": false,
    "noImplicitAny": true,
    "outDir": "./.temp",
    "rootDir": "./src",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "ES2023"
  },
  "exclude": ["node_modules", "dist", ".temp", "scripts"],
  "include": ["src/*.ts"]
}
